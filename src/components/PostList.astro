---
import type { CollectionEntry } from 'astro:content';
import { postHref } from '../lib/posts';
import TagList from './TagList.astro';

interface Props { posts: CollectionEntry<'posts'>[]; }
const { posts } = Astro.props;
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---
<ul class="post-list">
  {posts.map((p) => (
    <li>
      <a class="post-link" href={postHref(p.data.slug)}>{p.data.title}</a>
      <div class="meta">
        <time datetime={p.data.date.toISOString()}>{fmt(p.data.date)}</time>
        {p.data.tags.length > 0 && <TagList tags={p.data.tags} />}
      </div>
      {p.data.excerpt && <p class="excerpt">{p.data.excerpt}</p>}
    </li>
  ))}
</ul>

<style>
  .post-list { list-style: none; padding: 0; margin: 0; }
  .post-list li { padding: 1.5rem 0; border-bottom: 1px solid var(--border); }
  .post-list li:first-child { padding-top: 0; }
  .post-list li:last-child { border-bottom: 0; }
  .post-link { font-size: 1.2rem; font-weight: 600; color: var(--heading); }
  .post-link:hover { color: var(--accent); text-decoration: none; }
  .meta {
    display: flex; align-items: center; gap: 0.7rem; flex-wrap: wrap;
    margin-top: 0.4rem; color: var(--muted); font-size: 0.82rem;
  }
  .excerpt { margin: 0.55rem 0 0; color: var(--fg); opacity: 0.82; font-size: 0.96rem; }
</style>
