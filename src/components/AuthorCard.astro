---
import { SITE } from '../lib/site';
const { author } = SITE;
const base = import.meta.env.BASE_URL;
const aboutHref = `${base}${base.endsWith('/') ? '' : '/'}about-me/`;
---
<aside class="author-card">
  <img class="avatar" src={author.image} alt={author.name} width="84" height="84" loading="lazy" />
  <h2 class="name">{author.name}</h2>
  <p class="bio">{author.bio}</p>
  <ul class="links">
    {author.links.map((l) => (
      <li><a href={l.href} rel="me noopener" target="_blank">{l.label}</a></li>
    ))}
  </ul>
  <a class="more" href={aboutHref}>More about me →</a>
</aside>

<style>
  .author-card {
    position: sticky;
    top: 2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem 1.4rem;
  }
  .avatar {
    width: 84px;
    height: 84px;
    border-radius: 999px;
    object-fit: cover;
    margin: 0 0 0.9rem;
  }
  .name { font-size: 1.2rem; margin: 0 0 0.5rem; }
  .bio {
    color: var(--fg);
    opacity: 0.85;
    font-size: 0.92rem;
    line-height: 1.6;
    margin: 0 0 1rem;
  }
  .links {
    list-style: none;
    padding: 0;
    margin: 0 0 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .links a { color: var(--muted); font-size: 0.88rem; }
  .links a:hover { color: var(--accent); }
  .more { font-size: 0.9rem; font-weight: 600; }
  @media (max-width: 820px) {
    .author-card { position: static; }
  }
</style>
