---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="404 — Small World" description="Page not found">
  <div style="text-align:center; padding:3.5rem 0;">
    <h1 style="font-size:3rem; margin-bottom:0.4rem;">404</h1>
    <p style="color:var(--muted)">That page wandered off into a small world of its own.</p>
    <p style="margin-top:1.5rem;"><a href={base}>← Back home</a></p>
  </div>
</BaseLayout>
