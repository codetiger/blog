---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostList from '../../components/PostList.astro';
import Pager from '../../components/Pager.astro';
import { getSortedPosts, homeHref } from '../../lib/posts';
import { SITE } from '../../lib/site';

// Pages 2..N live here; page 1 is the root index. Page count is derived from the
// post total, so adding posts grows pagination automatically.
export async function getStaticPaths() {
  const all = await getSortedPosts();
  const size = SITE.pageSize;
  const total = Math.ceil(all.length / size);
  const paths = [];
  for (let n = 2; n <= total; n++) {
    paths.push({
      params: { page: String(n) },
      props: { posts: all.slice((n - 1) * size, n * size), page: n, total },
    });
  }
  return paths;
}

const { posts, page, total } = Astro.props;
const base = import.meta.env.BASE_URL;
const j = (p: string) => `${base}${base.endsWith('/') ? '' : '/'}${p}`;
const prev = page - 1 === 1 ? homeHref : j(`page/${page - 1}/`);
const next = page < total ? j(`page/${page + 1}/`) : null;
---

<BaseLayout title={`${SITE.title} — page ${page}`} description={SITE.description}>
  <PostList posts={posts} />
  <Pager prev={prev} next={next} />
</BaseLayout>
